# Port — Railway injects this automatically. Local dev defaults to 1234.
PORT=1234

# Supabase project — find at https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key — server-side only, NEVER expose to clients. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# JWT secret — used to verify access tokens from clients (HS256).
# Find at Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Optional: comma-separated list of allowed doc-name prefixes for extra safety.
# Example: ALLOWED_DOC_PREFIXES=project:,test:
# Leave empty to allow any doc name.
ALLOWED_DOC_PREFIXES=

# Log level: debug | info | warn | error
LOG_LEVEL=info
